# Puerto en el que se expone el servicio
PORT=3000

# URL del catálogo externo (DummyJSON)
EXTERNAL_API_URL=https://dummyjson.com/products/search?q=phone

# Impuesto aplicado sobre el precio base (16% = 0.16)
TAX_RATE=0.16

# Umbral para marcar isLowStock (true si stock < a este valor)
LOW_STOCK_THRESHOLD=10
